[gd_scene load_steps=2 format=3 uid="uid://shop00001"]

[ext_resource type="Script" path="res://scripts/ui/shop.gd" id="1_shop"]

[node name="Shop" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_shop")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.05, 0.1, 1)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 3
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -180.0
offset_top = -180.0
offset_right = 180.0
offset_bottom = 180.0
theme_override_constants/separation = 14

[node name="TitleLabel" type="Label" parent="VBox"]
text = "SHOP"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 36

[node name="FundsLabel" type="Label" parent="VBox"]
text = "Funds: 0.00"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20

[node name="ShieldsLabel" type="Label" parent="VBox"]
text = "Shields: 0"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20

[node name="ShieldPriceLabel" type="Label" parent="VBox"]
text = "1 Shield = 100 funds"
horizontal_alignment = 1

[node name="QuantityInput" type="SpinBox" parent="VBox"]
min_value = 1.0
max_value = 99.0
value = 1.0

[node name="BuyButton" type="Button" parent="VBox"]
text = "Buy Shields"

[node name="StatusLabel" type="Label" parent="VBox"]
text = ""
horizontal_alignment = 1
autowrap_mode = 3

[node name="BackButton" type="Button" parent="VBox"]
text = "Back"

[connection signal="pressed" from="VBox/BuyButton" to="." method="_on_buy_pressed"]
[connection signal="pressed" from="VBox/BackButton" to="." method="_on_back_pressed"]
